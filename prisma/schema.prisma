generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter")
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  campaigns    Campaign[]
  rules        Rule[]
  integrations Integration[]
  keywords     Keyword[]
  keywordRanks KeywordRank[]
  competitors  Competitor[]
  seoAudits    SeoAudit[]
  notifications Notification[]
  researchReports ResearchReport[]
  contentBriefs ContentBrief[]
  invites      TeamInvite[]
  auditLogs    AuditLog[]
  campaignAlerts CampaignAlert[]
  seoMonitors  SeoMonitor[]
  @@map("teams")
}

model User {
  id                  String    @id @default(uuid())
  teamId              String    @map("team_id")
  email               String    @unique
  name                String
  password            String
  role                String    @default("admin")
  isActive            Boolean   @default(true) @map("is_active")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpiry  DateTime? @map("password_reset_expiry")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  team          Team           @relation(fields: [teamId], references: [id])
  notifications Notification[]
  @@map("users")
}

model Campaign {
  id             String    @id @default(uuid())
  teamId         String    @map("team_id")
  name           String
  platform       String    // meta | google | both
  objective      String    @default("conversions")
  status         String    @default("draft")
  budget         Decimal   @default(0) @db.Decimal(12,2)
  budgetType     String    @default("daily") @map("budget_type")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  performance    Json      @default("{}") @db.JsonB
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  team   Team   @relation(fields: [teamId], references: [id])
  ads    Ad[]
  rules  Rule[]
  notifications Notification[]
  campaignAlerts CampaignAlert[]

  @@index([teamId, status])
  @@index([teamId, deletedAt])
  @@map("campaigns")
}

model Ad {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  headline    String
  primaryText String   @map("primary_text")
  description String?
  ctaType     String   @default("LEARN_MORE") @map("cta_type")
  imageUrl    String?  @map("image_url")
  landingUrl  String?  @map("landing_url")
  platform    String
  status      String   @default("draft")
  performance Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  @@map("ads")
}

model ResearchReport {
  id           String   @id @default(uuid())
  teamId       String   @map("team_id")
  query        String
  competitors  Json     @default("[]") @db.JsonB
  adAnalysis   Json     @default("{}") @db.JsonB
  keywords     Json     @default("[]") @db.JsonB
  suggestions  Json     @default("[]") @db.JsonB
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])
  @@map("research_reports")
}

model Competitor {
  id             String    @id @default(uuid())
  teamId         String    @map("team_id")
  name           String
  domain         String
  activeAdsCount Int       @default(0) @map("active_ads_count")
  topKeywords    Json      @default("[]") @db.JsonB
  lastScrapedAt  DateTime? @map("last_scraped_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])
  @@map("competitors")
}

model Keyword {
  id            String    @id @default(uuid())
  teamId        String    @map("team_id")
  keyword       String
  searchVolume  Int       @default(0) @map("search_volume")
  difficulty    Int       @default(0)
  currentRank   Int?      @map("current_rank")
  previousRank  Int?      @map("previous_rank")
  trackedUrl    String?   @map("tracked_url")
  lastCheckedAt DateTime? @map("last_checked_at")
  source        String    @default("manual")       // "manual" | "audit" | "ai"
  createdBy     String?   @map("created_by")       // userId who added it
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  team  Team          @relation(fields: [teamId], references: [id])
  ranks KeywordRank[]
  @@index([teamId, isActive])
  @@map("keywords")
}

model KeywordRank {
  id         String   @id @default(uuid())
  keywordId  String   @map("keyword_id")
  teamId     String   @map("team_id")
  rank       Int
  recordedAt DateTime @default(now()) @map("recorded_at")

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id])

  @@index([keywordId, recordedAt])
  @@index([teamId, recordedAt(sort: Desc)])
  @@map("keyword_ranks")
}

model SeoAudit {
  id            String   @id @default(uuid())
  teamId        String   @map("team_id")
  url           String
  status        String   @default("pending")
  engineVersion Int      @default(1) @map("engine_version")

  // ── Shared (both v1 and v2) ──────────────────────────────────────────────
  overallScore  Int?     @map("overall_score")
  grade         String?

  // ── v1 legacy columns — kept as-is; DB column names are camelCase (no @map) ──
  // Written by SeoAuditService (legacy engine). Nullable so v2 records leave them null.
  technicalIssues Json?  @db.JsonB
  recommendations Json?  @db.JsonB

  // ── v2 dedicated columns (AuditOrchestrator, engineVersion=2) ────────────
  // Full Issue[] from TechnicalAnalyzer, severity-sorted
  issues          Json?  @db.JsonB
  // PerformanceEngine result: { score, metrics, pagesAnalyzed, pageResults, fallback }
  performanceData Json?  @db.JsonB @map("performance_data")
  // ScoringEngine output: { categories, issueCount, deductionAudit }
  categoryScores  Json?  @db.JsonB @map("category_scores")
  // Crawl metadata: { crawlStats, brokenLinks, redirectChains } — NOT full pages[]
  rawCrawlData    Json?  @db.JsonB @map("raw_crawl_data")
  // LLM executive summary (null until SeoSummaryService is implemented)
  summary         String?

  createdAt     DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, status])
  @@index([teamId, createdAt])
  @@map("seo_audits")
}

model ContentBrief {
  id              String   @id @default(uuid())
  teamId          String   @map("team_id")
  targetKeyword   String   @map("target_keyword")
  title           String
  outline         Json     @default("[]") @db.JsonB
  relatedKeywords Json     @default("[]") @db.JsonB
  status          String   @default("draft")
  createdAt       DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])
  @@map("content_briefs")
}

model CampaignAlert {
  id          String    @id @default(uuid())
  teamId      String    @map("team_id")
  campaignId  String    @map("campaign_id")
  alertType   String    @map("alert_type")   // 'roas_drop' | 'ctr_collapse' | 'cpa_spike' | 'budget_bleed'
  threshold   Float
  action      String    // 'pause' | 'notify' | 'reduce_budget'
  actionValue Float?    @map("action_value")  // e.g. 20 for "reduce by 20%"
  isActive    Boolean   @default(true) @map("is_active")
  triggeredAt DateTime? @map("triggered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  team     Team     @relation(fields: [teamId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([teamId, campaignId])
  @@map("campaign_alerts")
}

model Rule {
  id               String   @id @default(uuid())
  teamId           String   @map("team_id")
  campaignId       String?  @map("campaign_id")
  triggerType      String   @map("trigger_type")
  triggerValue     Decimal  @db.Decimal(12,2) @map("trigger_value")
  action           String
  actionValue      Decimal? @db.Decimal(12,2) @map("action_value")
  isActive         Boolean  @default(true) @map("is_active")
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  createdAt        DateTime @default(now()) @map("created_at")

  team     Team      @relation(fields: [teamId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  @@map("rules")
}

model Notification {
  id         String    @id @default(uuid())
  teamId     String    @map("team_id")
  userId     String    @map("user_id")
  campaignId String?   @map("campaign_id")
  type       String
  channel    String    @default("in_app")
  message    String
  status     String    @default("pending")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  team     Team      @relation(fields: [teamId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  @@map("notifications")
}

model Integration {
  id             String    @id @default(uuid())
  teamId         String    @map("team_id")
  provider       String
  accountId      String?   @map("account_id")   // Meta ad account ID or Google customer ID
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  status         String    @default("active")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])
  @@unique([teamId, provider])
  @@map("integrations")
}
model TeamInvite {
  id        String    @id @default(uuid())
  teamId    String    @map("team_id")
  email     String
  role      String    @default("member")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, email])
  @@index([token])
  @@map("team_invites")
}

model SeoMonitor {
  id          String    @id @default(uuid())
  teamId      String    @map("team_id")
  url         String
  name        String
  status      String    @default("active")  // 'active' | 'paused' | 'running'
  schedule    String    @default("weekly")  // 'daily' | 'weekly'
  lastAuditId String?   @map("last_audit_id")
  lastScore   Int?      @map("last_score")
  lastGrade   String?   @map("last_grade")
  nextRunAt   DateTime? @map("next_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  team         Team           @relation(fields: [teamId], references: [id])
  scoreHistory ScoreHistory[]

  @@unique([teamId, url])
  @@index([teamId, status])
  @@map("seo_monitors")
}

model ScoreHistory {
  id           String   @id @default(uuid())
  monitorId    String   @map("monitor_id")
  auditId      String   @map("audit_id")
  score        Int
  grade        String?
  regressions  Int      @default(0)
  improvements Int      @default(0)
  alerts       Json     @default("[]") @db.JsonB
  recordedAt   DateTime @default(now()) @map("recorded_at")

  monitor SeoMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, recordedAt])
  @@map("score_history")
}

model AuditLog {
  id         String   @id @default(uuid())
  teamId     String   @map("team_id")
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json     @default("{}") @db.JsonB
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
