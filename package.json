{
  "name": "adpilot",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently -n \"api,web\" -c \"blue,green\" \"npm run dev\" \"cd client && npm run dev\"",
