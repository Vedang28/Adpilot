    "prisma": "^6.19.2",
    "@sentry/node": "^10.40.0",
    "axios": "^1.0.0",
    "bcrypt": "^5.0.0",
    "bull": "^4.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.5.1",
    "google-trends-api": "^4.9.2",
    "groq-sdk": "^0.37.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.0.0",
    "joi": "^17.0.0",
    "jsonwebtoken": "^9.0.0",
    "lighthouse": "^13.0.3",
    "natural": "^6.12.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
